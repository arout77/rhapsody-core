#!/usr/bin/env php
<?php

/**
 * Rhapsody Framework CLI Runner
 * vendor/arout/rhapsody-core/bin/rhapsody
 */

// 1. Establish the current working directory as the Application Base Path
$basePath = getcwd();

// 2. Locate the autoloader relative to the application executing the command
$autoloader = $basePath . '/vendor/autoload.php';

if (!file_exists($autoloader)) {
    echo "[\033[31mError\033[0m] Composer autoloader not found. Please run 'composer install' from the application root.\n";
    exit(1);
}

require_once $autoloader;

// 3. Define framework path constants safely targeting the consumer app
if (!defined('ROOT_DIR')) {
    define('ROOT_DIR', $basePath);
}

// 4. Load the Application's Bootstrap Environment (if it exists)
// This ensures your CLI commands have access to the DI Container, Configs, and DB Connections
$bootstrapPath = $basePath . '/bootstrap.php';

if (file_exists($bootstrapPath)) {
    // Expecting bootstrap.php to return your dependency injection container or application instance
    $app = require_once $bootstrapPath;
} else {
    echo "[\033[33mWarning\033[0m] Application bootstrap.php not found at root. Running in isolated core mode.\n";
}

// =========================================================================
// 5. Example CLI Command Router Logic
// =========================================================================

// Grab CLI arguments (excluding the script name itself)
$args = $argv;
array_shift($args); 

$command = $args[0] ?? 'help';

switch ($command) {
    case 'make:controller':
        $controllerName = $args[1] ?? null;
        if (!$controllerName) {
            echo "[\033[31mError\033[0m] Missing controller name. Usage: php rhapsody make:controller CleanController\n";
            exit(1);
        }
        
        // Target the APP's directory, NOT the vendor directory
        $targetDir = $basePath . '/app/Controllers';
        $targetFile = $targetDir . '/' . $controllerName . '.php';
        
        if (!is_dir($targetDir)) {
            mkdir($targetDir, 0755, true);
        }
        
        if (file_exists($targetFile)) {
            echo "[\033[31mError\033[0m] Controller {$controllerName} already exists in your application.\n";
            exit(1);
        }
        
        // Generate scaffold boilerplate
        $template = "<?php\n\nnamespace App\Controllers;\n\nclass {$controllerName}\n{\n    // Generated by Rhapsody Core CLI\n}\n";
        file_put_contents($targetFile, $template);
        
        echo "[\033[32mSuccess\033[0m] Created App Controller: /app/Controllers/{$controllerName}.php\n";
        break;

    case 'cache:clear':
        // Targets the consumer app's storage directory
        $cacheDir = $basePath . '/storage/cache';
        echo "Clearing application cache at: {$cacheDir}...\n";
        // (Add your file deletion loop utility here)
        echo "[\033[32mSuccess\033[0m] Application cache cleared.\n";
        break;

    case 'help':
    default:
        echo "\033[34mRhapsody Framework\033[0m CLI Engine\n";
        echo "----------------------------------------\n";
        echo "Available Commands:\n";
        echo "  make:controller [Name]   Scaffold a new application controller\n";
        echo "  cache:clear             Flush compiled views and router cache pools\n";
        break;
}