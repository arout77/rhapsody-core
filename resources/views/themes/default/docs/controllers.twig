        <li>Read about <a href="{{ base_url }}/docs/react">React Integration</a> for building modern SPAs.</li>
        <li>Check the <a href="{{ base_url }}/docs/performance">Performance</a> guide for lazy loading and caching.</li>
    </ul>

{% endblock %}