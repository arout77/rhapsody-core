{% extends "@core/emails/layout.twig" %}

{% block content %}
<h1 style="font-size: 24px; font-weight: 700; color: #1a202c; margin-bottom: 16px;">
    Welcome to {{ app_name|default('Rhapsody') }}, {{ name }}!
</h1>

<p style="font-size: 16px; line-height: 1.6; color: #4a5568; margin-bottom: 16px;">
    Thank you for creating an account. We're excited to have you on board!
</p>

<p style="font-size: 16px; line-height: 1.6; color: #4a5568; margin-bottom: 16px;">
    Here's what you can do next:
</p>

<ul style="font-size: 16px; line-height: 1.6; color: #4a5568; padding-left: 20px; margin-bottom: 16px;">
    <li>Explore the platform and discover all the features</li>
    <li>Update your profile with a photo and more details</li>
    <li>Connect with other members in the community</li>
    <li>Read and highlight verses in the Bible reader</li>
</ul>

<p style="font-size: 16px; line-height: 1.6; color: #4a5568; margin-bottom: 16px;">
    If you have any questions, don't hesitate to reach out to our support team.
</p>

<p style="font-size: 16px; line-height: 1.6; color: #4a5568; margin-top: 24px; padding-top: 16px; border-top: 1px solid #e2e8f0;">
    <a href="{{ base_url }}/dashboard" style="display: inline-block; background-color: #3182ce; color: #ffffff; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: 600;">
        Go to Dashboard
    </a>
</p>
{% endblock %}